# ── Server-side secrets (set in Vercel, never commit) ──────────
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Sentinel CRM integration ─────────────────────────────────
# Forward leads from /sell form directly into Sentinel CRM.
# SENTINEL_API_URL = your Sentinel deployment URL (no trailing slash)
# SENTINEL_INTAKE_SECRET = must match INBOUND_INTAKE_SECRET in Sentinel's env
SENTINEL_API_URL=
SENTINEL_INTAKE_SECRET=

# ── Public: Google Ads conversion labels (client-side) ─────────
# Set these after creating conversion actions in Google Ads:
#   Google Ads → Goals → Conversions → New conversion action → Website
#   Copy the conversion label (looks like "AbCdEfGhIjKlMn")
# Leave blank until configured — GA4 events fire regardless.
NEXT_PUBLIC_GADS_FORM_LABEL=
NEXT_PUBLIC_GADS_CALL_LABEL=
