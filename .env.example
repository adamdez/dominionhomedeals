# ── Server-side secrets (set in Vercel, never commit) ──────────
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Sentinel CRM integration ─────────────────────────────────
# Forward leads from /sell form directly into Sentinel CRM.
# SENTINEL_API_URL = your Sentinel deployment URL (no trailing slash)
# SENTINEL_INTAKE_SECRET = must match INBOUND_INTAKE_SECRET in Sentinel's env
SENTINEL_API_URL=
SENTINEL_INTAKE_SECRET=

# ── Al Boreland Command Center (/al) ─────────────────────────
AL_ACCESS_PASSWORD=
OPENAI_API_KEY=
AL_REASONING_PROVIDER=openai
AL_OPENAI_MODEL_FAST=gpt-5-mini
AL_OPENAI_MODEL_HEAVY=gpt-5.4
AL_CANONICAL_HOST=borelandops.com
# Optional explicit override if AL ever needs a non-default origin
# AL_CANONICAL_ORIGIN=https://borelandops.com
AL_BROWSER_RUNTIME=browserbase_first
AL_OPENCLAW_SHARED_SECRET=replace-with-a-long-random-shared-secret
AL_REMOTE_BRIDGE_SECRET=replace-with-a-long-random-relay-secret
# Optional fallback only — not the primary chairman path
ANTHROPIC_API_KEY=
# Hosted browser labor (primary when configured)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
STAGEHAND_MODEL_NAME=openai/gpt-4o-mini
WRENCHREADY_LOGO_URL=https://wrenchreadymobile.com/wr-logo-full.png
# Tavily web search — get a free key at https://tavily.com (1000 searches/mo free)
TAVILY_API_KEY=

# Supabase — enables trajectory logging (optional, chat works without it)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
AL_DELEGATE_SECRET=

# n8n — Al Obsidian vault write-back (publishes .md files to GitHub → Obsidian)
N8N_WEBHOOK_URL=

# ── Public: Google Ads (client-side) ───────────────────────────
# Optional: full send_to for lead form if Google Ads conversion action changes
# (default in code: AW-18000301728/LJHYCOnlx4QcEKCdm4dD)
# NEXT_PUBLIC_GADS_FORM_SEND_TO=
# Call conversion label (paired with AW-17989282213 in tracking.ts)
# NEXT_PUBLIC_GADS_CALL_LABEL=
# Optional proof assets for /sell pages
# NEXT_PUBLIC_OWNER_INTRO_VIDEO_EMBED_URL=
# NEXT_PUBLIC_SELLER_PROOF_FAMILIES_HELPED=
# NEXT_PUBLIC_SELLER_PROOF_SINCE_YEAR=
