{
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "al.dominionhomedeals.com" }],
      "destination": "/al/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/al/:path*",
      "has": [
        {
          "type": "host",
          "value": "(?!al\\.).*\\.?dominionhomedeals\\.com"
        }
      ],
      "destination": "https://al.dominionhomedeals.com/:path*",
      "permanent": true
    }
  ]
}
