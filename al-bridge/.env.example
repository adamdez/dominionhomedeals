# Full path to your Obsidian vault (required)
VAULT_PATH=C:\Users\adamd\path\to\your\ObsidianVault

# Bearer token for authentication (recommended for security)
BRIDGE_TOKEN=

# Port (default: 3141)
BRIDGE_PORT=3141

# CrewAI project (folder with main.py and crews/). Defaults to Desktop\al boreland-crew on Windows.
# CREW_PROJECT_ROOT=C:\Users\adamd\Desktop\al boreland-crew

# Brand media production lane (Runway + local source photos)
# SIMON_MEDIA_SOURCE_DIR=C:\Users\adamd\Desktop\Simon\simon
# RUNWAY_API_KEY=
# RUNWAY_MODEL_VIDEO=gen4_turbo
# RUNWAY_VIDEO_DURATION_SECONDS=10
# RUNWAY_VIDEO_RATIO=1280:720
# RUNWAY_API_VERSION=2024-11-06
